{
  "schema_version": 1,
  "bootstrap": {
    "magic": "CSEB",
    "version": 1
  },
  "framing": {
    "binary_element_type": "f32_le",
    "binary_layout": "row_major",
    "metadata_length": "u32_be",
    "payload_length": "u32_be"
  },
  "hello": {
    "required_client_fields": [
      "intent",
      "client_pid",
      "client_process_start_id",
      "client_executable_sha256",
      "client_executable_version"
    ],
    "transport_binding": {
      "security_boundary": "same_user_os_private_ipc",
      "authenticated_fields": [
        "client_pid",
        "client_process_start_id"
      ],
      "hello_fields_required_to_match": [
        "client_pid",
        "client_process_start_id"
      ]
    },
    "compatibility_attestation": {
      "client_digest_and_version_source": "same_user_hello_claim",
      "server_digest_and_version_source": "self_hashed_exact_executable_snapshot",
      "package_provenance_source": "external_installed_runtime_evidence"
    }
  },
  "limits": {
    "maximum_document_count": 2048,
    "maximum_input_bytes": 1048576,
    "maximum_metadata_bytes": 16777216,
    "maximum_payload_bytes": 16777216,
    "response_payload_count": 1
  },
  "lifecycle_states": [
    "absent",
    "draining",
    "exited",
    "listening",
    "resident",
    "sleeping",
    "unreachable",
    "waking"
  ],
  "operations": [
    "AcquireLease",
    "Cancel",
    "EmbedDocuments",
    "EmbedQuery",
    "EnsureResident",
    "Hello",
    "ReleaseLease",
    "Snapshot"
  ],
  "cancellation": {
    "eligible_operations": [
      "EmbedDocuments",
      "EmbedQuery"
    ],
    "embedding_request_shape": {
      "cancel_token": "optional_opaque_uuid"
    },
    "cancel_request_shape": {
      "target_request_id": "required",
      "cancel_token": "required_exact_match"
    },
    "authorization": {
      "token_match": "exact",
      "client_pid_match": "authenticated_hello_identity",
      "client_process_start_id_match": "authenticated_hello_identity",
      "ambiguous_target_match": "reject"
    },
    "snapshot_exposure": false,
    "diagnostic_exposure": false
  },
  "response_statuses": [
    "busy",
    "cancelled",
    "deadline_exceeded",
    "draining",
    "engine_stalled",
    "engine_unavailable",
    "incompatible",
    "internal_error",
    "ok",
    "protocol_error"
  ],
  "retry_classes": [
    "after_capacity_change",
    "after_delay",
    "after_owner_idle",
    "after_server_change",
    "none",
    "same_rpc_once",
    "terminal"
  ],
  "privacy": {
    "cancel_token_allowed_in_diagnostics": false,
    "cancel_token_allowed_in_snapshots": false,
    "project_path_allowed": false,
    "project_root_allowed": false,
    "repository_path_allowed": false,
    "request_text_allowed_in_diagnostics": false
  },
  "publication": {
    "pure_embedding_rpc_replay_limit": 1,
    "lease_operations_replayed": false,
    "lease_scope": [
      "authenticated_connection",
      "server_instance",
      "load_generation"
    ],
    "lease_revalidation": {
      "operation": "Snapshot",
      "returns_optional_engine_identity": true,
      "returns_optional_lease_identity": true
    },
    "manifest_last_revalidation": [
      "connection",
      "same_user_peer_and_hello_executable_attestation",
      "protocol",
      "server_instance",
      "lease",
      "producer_model_backend_policy_execution",
      "load_generation",
      "source",
      "core",
      "retrieval",
      "candidate_publication"
    ]
  }
}
