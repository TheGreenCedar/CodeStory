{
  "cases": [
    {
      "id": "runner-labels",
      "class_prefix": "[runner_labels]",
      "workflow": "macos-metal-proof.yml",
      "job": "packaged-metal",
      "field": [
        "runs-on"
      ],
      "value": [
        "self-hosted",
        "macOS",
        "ARM64"
      ]
    },
    {
      "id": "protected-environment",
      "class_prefix": "[protected_environment]",
      "workflow": "windows-vulkan-proof.yml",
      "job": "packaged-vulkan",
      "field": [
        "environment"
      ],
      "value": "release"
    },
    {
      "id": "permissions-secrets",
      "class_prefix": "[permissions_secrets]",
      "workflow": "release-candidate-evidence.yml",
      "field": [
        "permissions",
        "contents"
      ],
      "op": "delete"
    },
    {
      "id": "job-permissions-override",
      "class_prefix": "[permissions_secrets]",
      "workflow": "release-candidate-evidence.yml",
      "job": "measure",
      "field": [
        "permissions"
      ],
      "value": {
        "contents": "write"
      }
    },
    {
      "id": "protected-caller-secrets-inherit",
      "class_prefix": "[permissions_secrets]",
      "workflow": "packaged-platform-pr.yml",
      "job": "release-evidence",
      "field": [
        "secrets"
      ],
      "value": "inherit"
    },
    {
      "id": "protected-caller-undeclared-secret",
      "class_prefix": "[permissions_secrets]",
      "workflow": "release.yml",
      "job": "release-evidence",
      "field": [
        "secrets",
        "EXTRA_SECRET"
      ],
      "value": "${{ secrets.EXTRA_SECRET }}"
    },
    {
      "id": "artifact-retention",
      "class_prefix": "[artifact_retention]",
      "workflow": "release-candidate-evidence.yml",
      "job": "measure",
      "step": "Upload release evidence",
      "field": [
        "with",
        "retention-days"
      ],
      "value": 1
    },
    {
      "id": "exact-sha",
      "class_prefix": "[exact_sha]",
      "workflow": "release.yml",
      "job": "release-evidence",
      "field": [
        "with",
        "ref"
      ],
      "value": "${{ github.ref }}"
    },
    {
      "id": "promotion-boundary",
      "class_prefix": "[promotion_boundary]",
      "workflow": "release.yml",
      "job": "publish",
      "field": [
        "needs"
      ],
      "value": [
        "preflight",
        "packaged-proof"
      ]
    },
    {
      "id": "proof-contract",
      "class_prefix": "[proof_contract]",
      "workflow": "release.yml",
      "job": "release-evidence",
      "field": [
        "with",
        "profile"
      ],
      "value": "unattested-profile"
    },
    {
      "id": "target-matrix",
      "class_prefix": "[target_matrix]",
      "workflow": "post-publish-release-smoke.yml",
      "job": "smoke",
      "field": [
        "strategy",
        "matrix",
        "include"
      ],
      "value": []
    },
    {
      "id": "persistent-label",
      "class_prefix": "[persistent_label]",
      "workflow": "source-proof.yml",
      "field": [
        "on",
        "pull_request",
        "types"
      ],
      "value": [
        "labeled"
      ]
    }
  ]
}
