  "claims": [
    {
      "id": "source_behavior",
      "minimum_tier": "source",
      "depends_on_claims": [],
      "required_evidence": [
        "source_behavior"
      ],
      "prerequisite_checks": [
        {
          "id": "claim-graph-contract",
          "command": "node --test scripts/tests/codestory-release-claims.test.mjs"
        }
      ],
      "prerequisites": [
        "clean exact-SHA checkout",
        "locked dependency resolution",
        "source and contract tests pass"
      ],
      "non_claims": [
        "packaged archive identity",
        "installed or live runtime behavior"
      ],
      "accepted_risks": []
    },
    {
      "id": "package_identity",
      "minimum_tier": "package",
      "depends_on_claims": [
        "source_behavior"
      ],
      "required_evidence": [
        "package_identity"
      ],
      "prerequisite_checks": [
        {
          "id": "release-package-contract",
          "command": "python .github/scripts/package-codestory-release.py --self-test"
        }
      ],
      "prerequisites": [
        "package producer and embedded model contract are version matched",
        "archive checksum is bound to the exact source SHA and target"
      ],
      "non_claims": [
        "execution on every supported host",
        "accelerator execution"
      ],
      "accepted_risks": []
    },
    {
      "id": "platform_support",
      "minimum_tier": "native_platform",
      "depends_on_claims": [
        "package_identity"
      ],
      "required_evidence": [
        "platform_support"
      ],
      "prerequisite_checks": [
        {
          "id": "packaged-agent-contract",
          "command": "python .github/scripts/check-packaged-agent-proof.py --self-test"
        }
      ],
      "prerequisites": [
        "the attested archive executes on the named native OS and architecture",
        "platform-specific signing or installer checks pass where applicable"
      ],
      "non_claims": [
        "unsupported operating-system versions",
        "hardware acceleration on packaging-only cells"
      ],
      "accepted_risks": [
        "native-host-matrix-is-bounded"
      ]
    },
    {
      "id": "accelerator_execution",
      "minimum_tier": "protected_hardware",
      "depends_on_claims": [
        "package_identity"
      ],
      "required_evidence": [
        "accelerator_execution"
      ],
      "prerequisite_checks": [
        {
          "id": "packaged-agent-contract",
          "command": "python .github/scripts/check-packaged-agent-proof.py --self-test"
        }
      ],
      "prerequisites": [
        "protected hardware runner identity is exact",
        "CPU fallback is disabled",
        "the packaged binary reports and exercises the named backend"
      ],
      "non_claims": [
        "accelerators absent from the protected runner matrix",
        "answer quality"
      ],
      "accepted_risks": [
        "protected-hardware-matrix-is-bounded"
      ]
    },
    {
      "id": "installed_runtime_behavior",
      "minimum_tier": "installed_runtime",
      "depends_on_claims": [
        "package_identity"
      ],
      "required_evidence": [
        "installed_runtime_behavior"
      ],
      "prerequisite_checks": [
        {
          "id": "managed-install-contract",
          "command": "python .github/scripts/check-packaged-agent-proof.py --self-test"
        }
      ],
      "prerequisites": [
        "installer or managed-plugin handoff uses the attested archive",
        "installed runtime version and project-scoped behavior are observed after installation"
      ],
      "non_claims": [
        "fresh host-session visibility unless separately attested",
        "retrieval readiness"
      ],
      "accepted_risks": [
        "installed-host-matrix-is-bounded"
      ]
    },
    {
      "id": "retrieval_readiness",
      "minimum_tier": "live_behavior",
      "depends_on_claims": [
        "package_identity",
        "platform_support",
        "accelerator_execution"
      ],
      "required_evidence": [
        "retrieval_readiness"
      ],
      "prerequisite_checks": [
        {
          "id": "packaged-agent-contract",
          "command": "python .github/scripts/check-packaged-agent-proof.py --self-test"
        }
      ],
      "prerequisites": [
        "the exact packaged archive runs on protected release hardware",
        "packet and search complete on two project-bound plugin hosts",
        "live encoding and shared-server continuity remain observable"
      ],
      "non_claims": [
        "answer sufficiency for an unmeasured task",
        "performance outside the approved profile"
      ],
      "accepted_risks": [
        "measured-corpus-is-bounded"
      ]
    },
    {
      "id": "performance",
      "minimum_tier": "live_behavior",
      "depends_on_claims": [],
      "required_evidence": [
        "performance"
      ],
      "prerequisite_checks": [
        {
          "id": "release-evidence-contract",
          "command": "node --test scripts/tests/codestory-release-evidence-gate.test.mjs"
        }
      ],
      "prerequisites": [
        "metrics are derived from the approved profile and baseline",
        "candidate, baseline, artifacts, machine fingerprint, and exact source SHA are attested together"
      ],
      "non_claims": [
        "performance on other hardware or corpora",
        "future-regression immunity"
      ],
      "accepted_risks": [
        "performance-profile-is-bounded"
      ]
    },
    {
      "id": "answer_quality",
      "minimum_tier": "answer_quality",
      "depends_on_claims": [],
      "required_evidence": [
        "answer_quality"
      ],
      "prerequisite_checks": [
        {
          "id": "release-evidence-contract",
          "command": "node --test scripts/tests/codestory-release-evidence-gate.test.mjs"
        }
      ],
      "prerequisites": [
        "publishable packet rows pass sufficiency and provenance checks for every declared repeat",
        "evaluation contract and task set are named and bound to the exact source SHA"
      ],
      "non_claims": [
        "general quality for tasks outside the evaluation contract",
        "benchmark-driven production steering"
      ],
      "accepted_risks": [
        "evaluation-task-set-is-bounded"
      ]
    }
  ],
  "failure_controls": [
    {
      "id": "stale_or_partial_publication",
      "claim": "retrieval_readiness",
