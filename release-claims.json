      "command": "cargo test --locked -p codestory-cli --test stdio_protocol_contracts two_stdio_processes_observe_only_complete_generations_during_real_refresh"
    },
    {
      "id": "project_identity_drift",
      "claim": "retrieval_readiness",
      "control": "negative_gate",
