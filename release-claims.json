    {
      "id": "sidecar_runtime_mismatch",
      "claim": "retrieval_readiness",
      "control": "negative_gate",
      "command": "cargo test --locked -p codestory-contracts --lib package_runtime_sidecar_evidence_mismatch_requires_a_complete_rebuild"
    },
    {
      "id": "observational_read_mutation",
      "claim": "source_behavior",
      "control": "negative_gate",
      "command": "cargo test --locked -p codestory-cli --test stdio_protocol_contracts status_observes_staleness_and_ground_activates_bounded_local_refresh"
